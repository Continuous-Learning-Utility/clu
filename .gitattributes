# Auto-detect text files and normalize line endings
* text=auto

# Force LF for scripts and config
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.txt text eol=lf
*.cs text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
